{
  "name": "athlix-backend",
  "version": "1.0.0",
  "private": true,
  "description": "ATHLIX AI backend server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/services/parking.service.test.ts src/services/emergency.service.test.ts",
